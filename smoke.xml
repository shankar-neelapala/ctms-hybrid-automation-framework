      <class name="tests.studies.CreateStudy"/>
      <class name="tests.sites.CreateSite"/>
      <class name="tests.subjects.CreateSubject"/>
      <class name="tests.patients.RegisterPatient"/>
    </classes>
  </test>
</suite>